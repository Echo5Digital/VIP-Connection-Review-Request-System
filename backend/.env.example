PORT=4000
MONGODB_URI=mongodb://localhost:27017/review-request
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
EXPRESS_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Optional: seed first admin (only if no admins exist)
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_CLIENT_EMAIL=client@gmail.com
SEED_CLIENT_PASSWORD=change-me-client-password

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# Gmail SMTP
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_FROM_EMAIL=your-email@gmail.com
GMAIL_FROM_NAME="Review Request"

# SMTP (preferred)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="VIP Connection <yourgmail@gmail.com>"
